# Kopiere diese Datei zu .env und fülle die Werte aus
# .env wird NICHT auf GitHub hochgeladen

# Passwort für den App-Zugang (PFLICHT für Produktion)
APP_PASSWORD=dein-sicheres-passwort

# Benutzername (optional, Standard: admin)
APP_USERNAME=admin

# Basis-URL der App (für Shopify OAuth Callback)
# Lokal: http://localhost:3000
# Railway: https://deine-app.railway.app
BASE_URL=http://localhost:3000

# Port (Railway setzt diesen automatisch)
# PORT=3000
